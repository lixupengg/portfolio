/i>\n            <h3>Email Me</h3>\n            <p>contact@example.com</p>\n          </div>\n        </div>\n        <div class=\"col-md-6 mt-4 d-flex align-items-stretch\">\n          <div class=\"info-box\">\n            <i class=\"logo bx bx-phone-call\"></i>\n            <h3>Call Me</h3>\n            <p>+1 5589 55488 55</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n       );\n  }\n}\n\nexport default ContactMe;\n","/Users/lixupeng/Local Work/cny-lohei/src/Pages/Footer.jsx",["130","131","132","133","134","135"],"// Basic Imports\nimport React, { Component, Fragment } from \"react\";\n// -------------------------------------------------------------------------\n\nimport './Page.css';\n\nclass Footer extends Component{\n  render() {\n      return (\n        <footer id=\"footer\">\n          <div class=\"container\">\n            <h3>LI XUPENG</h3>\n            <p>Et aut eum quis fuga eos sunt ipsa nihil. Labore corporis magni eligendi fuga maxime saepe commodi placeat.</p>\n            <div class=\"social-links\">\n              <a href=\"#\" class=\"twitter\"><i class=\"bx bxl-twitter\"></i></a>\n              <a href=\"#\" class=\"facebook\"><i class=\"bx bxl-facebook\"></i></a>\n              <a href=\"#\" class=\"instagram\"><i class=\"bx bxl-instagram\"></i></a>\n              <a href=\"#\" class=\"google-plus\"><i class=\"bx bxl-skype\"></i></a>\n              <a href=\"#\" class=\"linkedin\"><i class=\"bx bxl-linkedin\"></i></a>\n            </div>\n          </div>\n        </footer>\n       );\n  }\n}\n\nexport default Footer;\n","/Users/lixupeng/Local Work/cny-lohei/src/Components/MyCarousel.jsx",["136","137","138","139","140","141","142","143"],{"ruleId":"144","replacedBy":"145"},{"ruleId":"146","replacedBy":"147"},{"ruleId":"148","severity":1,"message":"149","line":2,"column":28,"nodeType":"150","messageId":"151","endLine":2,"endColumn":36},{"ruleId":"148","severity":1,"message":"152","line":10,"column":8,"nodeType":"15