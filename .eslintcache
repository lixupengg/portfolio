a-valuemax=\"100\"></div>\n              </div>\n            </div>\n\n            <div className=\"progress\">\n              <span className=\"skill\">Typescript <i className=\"val\">80%</i></span>\n              <div className=\"progress-bar-wrap\">\n                <div style={{width: '80%'}} className=\"progress-bar progress-bar-green\" role=\"progressbar\" aria-valuenow=\"80\" aria-valuemin=\"0\" aria-valuemax=\"100\"></div>\n              </div>\n            </div>\n\n            <div className=\"progress\">\n              <span className=\"skill\">Java <i className=\"val\">90%</i></span>\n              <div className=\"progress-bar-wrap\">\n                <div style={{width: '90%'}} className=\"progress-bar progress-bar-green\" role=\"progressbar\" aria-valuenow=\"90\" aria-valuemin=\"0\" aria-valuemax=\"100\"></div>\n              </div>\n            </div>\n\n            <div className=\"progress\">\n              <span className=\"skill\">Python <i className=\"val\">75%</i></span>\n              <div className=\"progress-bar-wrap\">\n                <div style={{width: '75%'}} className=\"progress-bar progress-bar-green\" role=\"progressbar\" aria-valuenow=\"55\" aria-valuemin=\"0\" aria-valuemax=\"100\"></div>\n              </div>\n            </div>\n\n            <div className=\"progress\">\n              <span className=\"skill\">C <i className=\"val\">60%</i></span>\n              <div className=\"progress-bar-wrap\">\n                <div style={{width: '60%'}} className=\"progress-bar progress-bar-green\" role=\"progressbar\" aria-valuenow=\"55\" aria-valuemin=\"0\" aria-valuemax=\"100\"></div>\n              </div>\n            </div>\n\n            <div className=\"progress\">\n              <span className=\"skill\">HTML5 <i className=\"val\">90%</i></span>\n              <div className=\"progress-bar-wrap\">\n                <div style={{width: '90%'}} className=\"progress-bar progress-bar-green\" role=\"progressbar \" aria-valuenow=\"75\" aria-valuemin=\"0\" aria-valuemax=\"100\"></div>\n              </div>\n            </div>\n\n            <div className=\"progress\">\n              <span className=\"skill\">CSS <i className=\"val\">85%</i></span>\n              <div className=\"progress-bar-wrap\">\n                <div style={{width: '85%'}} className=\"progress-bar progress-bar-green\" role=\"progressbar\" aria-valuenow=\"75\" aria-valuemin=\"0\" aria-valuemax=\"100\"></div>\n              </div>\n            </div>\n          </div>\n          </Reveal>\n\n        </div>\n\n      </div>\n    </section>\n       );\n  }\n}\n\nexport default Skills;\n","/Users/lixupeng/Local-Work/lixupeng/src/Pages/Page.jsx",["111"],"// Basic Imports\nimport React, { Component, Fragment } from \"react\";\n// -------------------------------------------------------------------------\n\nimport resume from \"../lixupeng.pdf\"\nimport Button from \"../Components/Button.jsx\"\n\nimport './Page.css';\n\nclass Page extends Component{\n  render() {\n      return (\n      \t<div class=\"pageContainer\">\n\t      \t<div class=\"introTextContainer\">\n            <p class=\"tagFont animate__animated animate__fadeInLeft\"> {\"<h1>\"} </p>\n\n            <div class=\"sentence animate__animated animate__fadeInLeft\">\n\t           <p class=\"introFont\"> Hi, </p>\n            </div>\n\n            <div class=\"sentence animate__animated animate__fadeInLeft animate__delay-1s\">\n              <p class=\"introFont\"> I'm </p>\n              <div class=\"xupengContainer\">\n  \t           <p class=\"introFont\"> Xupeng </p>\n               <p class=\"introFont green\">X</p>\n               <p class=\"introFont red\">X</p>\n              </div>\n              <p class=\"tagFont\"> {\"</h1>\"} </p>\n            </div>\n\n            <div class=\"sentence animate__animated animate__fadeInLeft animate__delay-1s\">\n              <p> An aspiring software engineer, currently a penultimate student in NUS computer science. </p>\n            </div>\n\t        </div>\n\n          <div class=\"detailsContainer\">\n            <div class=\"animate__animated animate__fadeIn animate__delay-1s\">\n                <Button link={resume} buttonContent=\"Download Resume\"/>\n            </div>\n          </div>\n\n          <div class=\"animate__animated animate__fadeIn animate__delay-1s\">\n            <p class = \"scrolldownFont left\"> scroll down! >> </p>\n          </div>\n          \n\n        </div>\n\n       );\n  }\n}\n\nexport default Page;\n","/Users/lixupeng/Local-Work/lixupeng/src/Pages/Footer.jsx",["112","113","114"],"// Basic Imports\nimport React, { Component, Fragment } from \"react\";\n// -------------------------------------------------------------------------\n\nimport './Page.css';\n\nclass Footer extends Component{\n  render() {\n      return (\n        <footer id=\"footer\">\n          <div class=\"container\">\n            <h3>LI XUPENG</h3>\n            <p>Thank you for reaching the end of my portfolio. Feel free to contact me to find out more!</p>\n            <div class=\"social-links\">\n              <a href=\"https://www.linkedin.com/in/lixupeng\" target=\"_blank\" class=\"instagram\"><i class=\"bx bxl-linkedin\"></i></a>\n              <a href=\"https://github.com/pongzers\" target=\"_blank\" class=\"linkedin\"><i class=\"bx bxl-github\"></i></a>\n            </div>\n          </div>\n        </footer>\n       );\n  }\n}\n\nexport default Footer;\n","/Users/lixupeng/Local-Work/lixupeng/src/Pages/Resume.jsx",["115","116","117","118","119","120"],"// Basic Imports\nimport React, { Component, Fragment } from \"react\";\n// -------------------------------------------------------------------------\nimport SingleProject from '../Components/SingleProject.jsx'\nimport trippyy from '../Assets/trippyy.PNG'\nimport wsg from '../Assets/WSG.png'\nimport scdf from '../Assets/scdf.png'\nimport uniquirk from '../Assets/uniquirk.png'\n\nimport './Page.css';\n\nclass Resume extends Component{\n\n\trender() {\n\t    return <section id=\"resume\" class=\"resume\">\n\t      <div class=\"container\" data-aos=\"fade-up\">\n\n\t        <div class=\"section-title\">\n\t          <h2 class=\"resume-title\">Resume</h2>\n\t        </div>\n\n\t        <div class=\"row\">\n\t          <div class=\"col-lg-6\">\n\t            <h3 class=\"resume-title\">Summary</h3>\n\t            <div class=\"resume-item pb-0\">\n\t              <h4>LI XUPENG</h4>\n\t              <p><em>Always excited to start on new projects, an astute thinker who is driven in catalysing improvements in current systems, while gaining insights from peers and seniors of different expertise. \n\t              A current Computer Science major, deeply interested in further developing full stack skillsets. </em></p>\n\t              <ul>\n\t                <li>(+65) 93898691</li>\n\t                <li>li.xupeng@u.nus.edu</li>\n\t              </ul>\n\t            </div>\n\n\t            <h3 class=\"resume-title\">Education</h3>\n\t\t\t\t<div class=\"resume-item\">\n\t              <h4>NOC Silicon Valley Batch 40, Entrepreneurial Studies</h4>\n\t              <h5>Jul 2021 - Present</h5>\n\t              <p><em>NUS Overseas Colleges</em></p>\n\t            </div>\n\t            <div class=\"resume-item\">\n\t              <h4>Bachelor of Computing (Honours) in Computer Science</h4>\n\t              <h5>Aug 2019 - Present</h5>\n\t              <p><em>National University of Singapore</em></p>\n\t              <p>Expected Graduation: May 2023</p>\n\t            </div>\n\t            <div class=\"resume-item\">\n\t              <h4>Singapore-Cambridge General Certificate of Education Advanced Level</h4>\n\t              <h5>Jan 2015 - Dec 2016</h5>\n\t              <p><em>Nanyang Junior College</em></p>\n\t            </div>\n\t          </div>\n\t          <div class=\"col-lg-6\">\n\t            <h3 class=\"resume-title\">Experience</h3>\n\t            <div class=\"resume-item\">\n\t              <h4>Full Stack Software Engineer Intern</h4>\n\t              <h5>Jul 2021 - Present</h5>\n\t              <p><em> Sellgo, Portland, Oregon </em></p>\n\t              <ul>\n\t                <li> Development of frontend interface for Sellgo Web Application (Amazon Analytics Dashboards), Chrome Extension (Amazon Product Analysis tool), and website.</li>\n\t                <li> Development of backend REST APIs with a focus on Amazon product scrapping, payments, and user management related features.</li>\n\t\t\t\t\t<li> Utilising ReactJS, NextJS, Typescript, Sass, Django </li>\n\t              </ul>\n\t            </div>\n\t            <div class=\"resume-item\">\n\t              <h4>Teaching Assistant</h4>\n\t              <h5>Jul 2020 - Jul 2021</h5>\n\t              <p><em>National University of Singapore </em></p>\n\t              <ul>\n\t                <li>Teaching assistant for CS1101S Programming Methodology, a rigorous and thorough introduction to programming and programming methodology for NUS Computer Science students.</li>\n\t                <li>Responsible for the conduct of tutorials and grading of assignments.</li>\n\t              </ul>\n\t            </div>\n\t            <div class=\"resume-item\">\n\t              <h4>Risk Assurance and Regulations Compliance Intern</h4>\n\t              <h5>Mar 2019 - Aug 2019</h5>\n\t              <p><em>PricewaterhouseCoopers Singapore</em></p>\n\t              <ul>\n\t                <li>Automated Excel procedures to extract data via writing scripts with Excel VBA, increasing efficiency in handling large volumes of insurance cases</li>\n\t                <li>Conceptualized and streamlined documentation workflow during project infancy\nstage with a client Insurance company in order to accurately meet compliance\nregulations, set out by the Monetary Authority of Singapore (MAS)</li>\n\t                <li>Spearheaded analysis and consolidation of data required for ad-hoc reports and\nprojects</li>\n\t              </ul>\n\t            </div>\n\t           \t<div class=\"resume-item\">\n\t              <h4>Sales Support Intern</h4>\n\t              <h5>Nov 2018 - Mar 2019</h5>\n\t              <p><em>Panalpina Singapore</em></p>\n\t              <ul>\n\t                <li>Automated Excel procedures to create quotations via writing scripts with Excel VBA,\nimproving efficiency of day to day operations</li>\n\t                <li>Responsible for pricing analysis and generated quotations for SME businesses</li>\n\t                <li>Assisted Business Development Managers and Key Account Managers with new and\nexisting businesses and joined on business meetings </li>\n\t              </ul>\n\t            </div>\n\t          </div>\n\t        </div>\n\n\t      </div>\n\t    </section>\n\t}\n\n }\n export default Resume;","/Users/lixupeng/Local-Work/lixupeng/src/Components/MyCarousel.jsx",["121","122","123","124","125","126","127","128"],"import React, { Component, Fragment } from \"react\";\n// -------------------------------------------------------------------------\nimport SingleProject from '../Components/SingleProject.jsx'\nimport Popup from \"reactjs-popup\";\nimport trippyy from '../Assets/trippyy-1.png'\nimport trippyy1 from '../Assets/trippyy-2.png'\nimport trippyy2 from '../Assets/trippyy-3.png'\nimport trippyy3 from '../Assets/trippyy-4.png'\nimport { Carousel } from 'react-responsive-carousel';\nimport \"react-responsive-carousel/lib/styles/carousel.min.css\"; // requires a loader\nimport \"./MyCarousel.css\"\n\nclass MyCarousel extends Component{\n\nstate = {\n\topen: false\n}\n\n  render() {\n      return (\n        <div className =\"carouselContainer\">\n      \t<Carousel \n          className=\"carousel-wrapper\"\n      \t\tautoPlay = \"True\"\n      \t\tstopOnHover= \"true\"\n      \t\tinfiniteLoop = \"true\"\n      \t\tdynamicHeight = \"true\"\n          showThumbs={false}\n      \t>\n            {this.props.samples.map((sample) => \n              <div className=\"picBox\">\n    